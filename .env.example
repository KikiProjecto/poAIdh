# ============================================================
# POIDH Autonomous Bounty Bot — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Wallet ───────────────────────────────────────────────────
# The bot's EOA private key (controls bounty creation & payouts)
# Generate a fresh wallet: cast wallet new (foundry) or ethers.Wallet.createRandom()
BOT_PRIVATE_KEY=0xyour_private_key_here

# ── Chain Selection ──────────────────────────────────────────
# Options: arbitrum | base | degen
CHAIN=arbitrum

# RPC URLs (use Alchemy/Infura/Quicknode for reliability)
ARB_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
DEGEN_RPC_URL=https://rpc.degen.tips

# POIDH Contract Addresses (verify these on poidh.xyz before use)
ARB_CONTRACT_ADDRESS=0xdffe8a4a4103f968ffd61fd082d08c41dcf9b940
BASE_CONTRACT_ADDRESS=
DEGEN_CONTRACT_ADDRESS=

# ── Bounty Settings ──────────────────────────────────────────
# Amount to fund each bounty (in ETH/native currency)
BOUNTY_AMOUNT_ETH=0.002

# How many hours to keep the bounty open for submissions
BOUNTY_DURATION_HOURS=48

# How often to poll for new submissions (milliseconds)
POLL_INTERVAL_MS=60000

# ── AI Evaluation ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Social Media (at least one required for full compliance) ─

# X (Twitter) — OAuth 1.0a credentials
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BEARER_TOKEN=

# Farcaster — via Neynar
NEYNAR_API_KEY=
FARCASTER_SIGNER_UUID=

# ── State & Logging ──────────────────────────────────────────
# Path to persistent state file (bot resumes from here if restarted)
STATE_FILE=./bot-state.json

# ── POIDH API ────────────────────────────────────────────────
# Optional: POIDH public API base URL for richer claim metadata
POIDH_API_BASE=https://poidh.xyz/api
